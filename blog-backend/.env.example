# Docker Compose 环境变量配置
# 复制此文件为 .env 并修改相应值

# MySQL 配置
MYSQL_ROOT_PASSWORD=root_password_change_me
MYSQL_DATABASE=pxczxn-blog
MYSQL_USER=pxczxn
MYSQL_PASSWORD=pxczxn
MYSQL_PORT=3306

# 应用配置
APP_PORT=8080

# JWT 配置
JWT_SECRET=please-change-this-to-a-secure-secret-key-min-32-chars-in-production
JWT_EXPIRATION=86400000
